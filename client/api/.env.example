# SMTP (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: "From" address (defaults to SMTP_USER)
# SMTP_FROM=contact@yoursite.com

# Where to receive contact form submissions
CONTACT_TO=you@example.com

# Optional: API server port (default 3001)
# PORT=3001
